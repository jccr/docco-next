{
  "name": "@jccr/docco-next",
  "description": "Literate programming parser",
  "keywords": [
    "documentation",
    "generator",
    "literate",
    "literate programming"
  ],
  "scripts": {
    "lint": "eslint --fix .",
    "docs": "bin/docco -o . -l plain -x md './docco.js'; mv docco.md README.md; bin/docco -l parallel --no-shiki-diff -o docs 'docco.js'; mv docs/docco.html docs/index.html"
  },
  "contributors": [
    "Tony Mobily",
    "Seb Insua"
  ],
  "version": "0.11.0",
  "license": "GPL3",
  "repository": {
    "type": "git",
    "url": "https://github.com/mobily-enterprises/docco-next"
  },
  "engines": {
    "node": ">= 18.0"
  },
  "type": "module",
  "dependencies": {
    "@shikijs/transformers": "^4.0.2",
    "commander": "^12.1.0",
    "ejs": "^3.1.10",
    "fs-extra": "^11.2.0",
    "globby": "^14.0.2",
    "marked": "^15.0.0",
    "marked-gfm-heading-id": "^4.1.4",
    "marked-smartypants": "^1.1.12",
    "shiki": "^1.22.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "eslint": "^9.14.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.13.1",
    "eslint-plugin-promise": "^7.1.0",
    "globals": "^15.12.0"
  },
  "main": "./docco.js",
  "bin": {
    "docco": "./bin/docco",
    "docco-next": "./bin/docco"
  },
  "files": [
    "./bin",
    "./layouts",
    "./docco.js"
  ],
  "publishConfig": {
    "access": "public"
  }
}
